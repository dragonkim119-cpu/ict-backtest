BINANCE_API_BASE=https://fapi.binance.com
DATA_DIR=./data
SQLITE_PATH=./data/backtest.sqlite

# Telegram bot alerts (optional)
# 1. Create bot via BotFather → get token
# 2. Start chat with bot, send any message
# 3. GET https://api.telegram.org/bot<TOKEN>/getUpdates → get chat_id
TELEGRAM_BOT_TOKEN=123456789:AAABBBCCC...
TELEGRAM_CHAT_ID=987654321
TELEGRAM_ALERT_THRESHOLD=5

# Macro dashboard (optional)
# Finnhub: https://finnhub.io → Dashboard → API Key (free, no card required)
# Provides: economic calendar (FOMC/CPI/NFP) + crypto/macro news
FINNHUB_API_KEY=your_finnhub_key_here
# RSS feeds (CoinDesk, Cointelegraph) are fetched automatically — no key needed
